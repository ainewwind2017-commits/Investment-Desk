import pandas as pd
import datetime

# 数据加载
themes = pd.read_csv('themes.csv')
stock_pool = pd.read_csv('stock_pool_v15_7.csv')

# 策略参数
TOTAL_ASSET = 1000000  # 示例总资产，可替换
STANDARD_UNIT = 0.025  # 单次买入占比
MAX_UNIT = 0.08        # 普通单票累计上限
CORE_UNIT = 0.10       # 核心龙头单票上限
DEFENSIVE_MIN = 0.05   # 防守仓最低保留

# 市场状态机判定函数
def get_market_state(df):
    # 检查沪深300和中证1000均线
    hs300_above_ma20 = df.loc['HS300', 'close'] > df.loc['HS300', 'MA20']
    zz1000_above_ma20 = df.loc['ZZ1000', 'close'] > df.loc['ZZ1000', 'MA20']
    zz1000_stronger = df.loc['ZZ1000', 'rsi'] > df.loc['HS300', 'rsi']

    if hs300_above_ma20 and zz1000_above_ma20 and zz1000_stronger:
        return 'strong_bull'
    elif hs300_above_ma20 or zz1000_above_ma20:
        return 'attack'
    else:
        return 'defensive'

# 买点函数
def check_buy_point(stock, theme_state):
    if theme_state in ['主攻', '试错']:
        return True
    return False

# 卖出函数
def check_sell_point(stock_price, ma20, ma30, loss_pct, upper_limit):
    if stock_price < ma30 or loss_pct >= 0.12 or stock_price > upper_limit:
        return 'sell'
    elif stock_price < ma20 or loss_pct >= 0.08:
        return 'reduce'
    return 'hold'

# 执行示例
for idx, row in stock_pool.iterrows():
    theme = row['theme']
    theme_row = themes[(themes['date'] == datetime.date.today().isoformat()) & (themes['theme'] == theme)]
    theme_state = theme_row['state'].values[0] if not theme_row.empty else '观察'
    
    if check_buy_point(row, theme_state):
        print(f"{row['stock_code']} 满足买点, 可买 {STANDARD_UNIT*TOTAL_ASSET:.2f} 元")
    
    sell_action = check_sell_point(row['close'], row['MA20'], row['MA30'], row['loss_pct'], CORE_UNIT*TOTAL_ASSET)
    if sell_action != 'hold':
        print(f"{row['stock_code']} 执行 {sell_action}")
